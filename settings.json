    "max_results": 20
  },
  "batch": {
    "recommended_confirmation_minutes": 10,
    "checkpoint_retention_days": 7
  },
  "audit": {"enabled": true, "retention_days": 30},
  "features": {"dart_fulltext": true, "kind_search": false, "orchestrator": true}
}
